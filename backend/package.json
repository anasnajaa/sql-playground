{
  "name": "sql-playground-backend",
  "version": "1.0.0",
  "description": "MSSQL playground API for sql.kuwaitdevs.com",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "reset-db": "node -e \"require('dotenv').config(); const {resetDatabase} = require('./src/services/resetService'); resetDatabase().then(r => { console.log('Reset complete:', r); process.exit(0); }).catch(e => { console.error('Reset failed:', e.message); process.exit(1); })\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "csv-parse": "^7.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "form-data": "^4.0.6",
    "jsonwebtoken": "^9.0.3",
    "mailgun.js": "^13.2.0",
    "mongoose": "^9.7.0",
    "mssql": "^10.0.4",
    "multer": "^2.1.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
