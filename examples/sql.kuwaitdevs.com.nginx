server {
    listen 80;
    server_name sql.kuwaitdevs.com;

    # Redirect all HTTP to HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name sql.kuwaitdevs.com;

    # SSL — managed by certbot
    ssl_certificate     /etc/letsencrypt/live/sql.kuwaitdevs.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/sql.kuwaitdevs.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # Security headers
    add_header X-Content-Type-Options  nosniff;
    add_header X-Frame-Options         DENY;
    add_header X-XSS-Protection        "1; mode=block";
    add_header Referrer-Policy         "strict-origin-when-cross-origin";

    charset utf-8;

    # ── API: proxy to Node.js Express backend ─────────────────────
    location /api/ {
        proxy_pass         http://127.0.0.1:3456/api/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
        proxy_send_timeout 30s;

        # Buffer tweaks for potentially large result sets
        proxy_buffer_size       16k;
        proxy_buffers           4 32k;
        proxy_busy_buffers_size 64k;
    }

    # ── Frontend: serve React build (static files) ─────────────────
    root /root/sql-playground/frontend/dist;

    location / {
        try_files $uri $uri/ /index.html;
        expires   1h;
        add_header Cache-Control "public, max-age=3600";
    }

    # Aggressive caching for hashed Vite assets
    location /assets/ {
        expires   1y;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # Disable direct access to .env or hidden files
    location ~ /\. {
        deny all;
    }

    error_log  /var/log/nginx/sql.kuwaitdevs.com.error.log;
    access_log /var/log/nginx/sql.kuwaitdevs.com.access.log;
}
